    },
    {
      "start": 282.183,
      "end": 285.0,
      "text": "Du kannst mit 60"
    },
    {
      "start": 282.183,
      "end": 285.0,
      "text": "von einer Leiter fallen."
    },
    {
      "start": 285.15,
      "end": 288.25,
      "text": "Tag für Tag würfelt das Universum"
    },
    {
      "start": 285.15,
      "end": 288.25,
      "text": "für jeden Menschen."
    },
    {
      "start": 288.3,
      "end": 292.033,
      "text": "Und Tag für Tag hat irgendjemand"
    },
    {
      "start": 288.3,
      "end": 292.033,
      "text": "auf diesem Planeten Pech."
    },
    {
      "start": 292.117,
      "end": 293.45,
      "text": "Und je älter du wirst,"
    },
    {
      "start": 293.5,
      "end": 295.567,
      "text": "umso mehr wird gewürfelt."
    },
    {
      "start": 296.117,
      "end": 298.983,
      "text": "Während du so durch den Ozean"
    },
    {
      "start": 296.117,
      "end": 298.983,
      "text": "deines Lebens schwimmst,"
    },
    {
      "start": 299.033,
      "end": 301.3,
      "text": "denkst du meistens nicht"
    },
    {
      "start": 299.033,
      "end": 301.3,
      "text": "über all das nach."
    },
    {
      "start": 301.35,
      "end": 302.8,
      "text": "Und das ist auch gut so."
    },
    {
      "start": 302.85,
      "end": 304.9,
      "text": "Das Lebens selbst nimmt dich ein,"
    },
    {
      "start": 304.95,
      "end": 307.983,
      "text": "und die Zukunft"
    },
    {
      "start": 304.95,
      "end": 307.983,
      "text": "ist irgendwie vage und schräg."
    },
    {
      "start": 308.1,
      "end": 310.9,
      "text": "Hin und wieder darüber nachzudenken"
    },
    {
      "start": 308.1,
      "end": 310.9,
      "text": "kann aber helfen,"
    },
    {
      "start": 310.95,
      "end": 313.967,
      "text": "dir wieder klarzumachen,"
    },
    {
      "start": 310.95,
      "end": 313.967,
      "text": "was du im Leben wirklich willst."
    },
    {
      "start": 314.017,
      "end": 316.4,
      "text": "Damit du später"
    },
    {
      "start": 314.017,
      "end": 316.4,
      "text": "möglichst wenig bedauerst."
    },
    {
      "start": 316.45,
      "end": 318.567,
      "text": "Und um dir in Erinnerung zu rufen,"
    },
    {
      "start": 318.617,
      "end": 320.91700000000003,
      "text": "dass du die Zeit,"
    },
    {
      "start": 318.617,
      "end": 320.91700000000003,
      "text": "die du heute nicht nutzt,"
    },
    {
      "start": 320.967,
      "end": 323.117,
      "text": "morgen vielleicht nicht mehr kriegst."
    },
    {
      "start": 323.183,
      "end": 325.7,
      "text": "Das Leben ist kompliziert,"
    },
    {
      "start": 323.183,
      "end": 325.7,
      "text": "und es ist schwierig,"
    },
    {
      "start": 325.75,
      "end": 329.017,
      "text": "sich zwischen all den Leuten"
    },
    {
      "start": 325.75,
      "end": 329.017,
      "text": "und Dingen, die dir wichtig sind,"
    },
    {
      "start": 329.08299999999997,
      "end": 330.08299999999997,
      "text": "zu entscheiden."
    },
    {
      "start": 330.133,
      "end": 333.41700000000003,
      "text": "Genau das wurde Milliarden Menschen"
    },
    {
      "start": 330.133,
      "end": 333.41700000000003,
      "text": "während der Coronapandemie"
    },
    {
      "start": 333.467,
      "end": 335.83299999999997,
      "text": "auf schmerzhafte"
    },
    {
      "start": 333.467,
      "end": 335.83299999999997,
      "text": "Art und Weise bewusst."
    },
    {
      "start": 335.883,
      "end": 338.367,
      "text": "Hast du dich"
    },
    {
      "start": 335.883,
      "end": 338.367,
      "text": "an Social Distancing gehalten,"
    },
    {
      "start": 338.41700000000003,
      "end": 341.41700000000003,
      "text": "konntest du plötzlich"
    },
    {
      "start": 338.41700000000003,
      "end": 341.41700000000003,
      "text": "ganz viele Dinge nicht mehr machen,"
    },
    {
      "start": 341.467,
      "end": 343.433,
      "text": "die vorher selbstverständlich waren."
    },
    {
      "start": 343.483,
      "end": 345.967,
      "text": "Reisen, öffentliche Orte besuchen,"
    },
    {
      "start": 343.483,
      "end": 345.967,
      "text": "Essen gehen,"
    },
    {
      "start": 346.017,
      "end": 348.05,
      "text": "Freunde treffen,"
    },
    {
      "start": 346.017,
      "end": 348.05,
      "text": "Menschen kennenlernen."
    },
    {
      "start": 348.1,
      "end": 349.1,
      "text": "(Lachen)"
    },
    {
      "start": 349.15,
      "end": 351.733,
      "text": "Die Zeit, die du"
    },
    {
      "start": 349.15,
      "end": 351.733,
      "text": "mit anderen verbringen konntest,"
    },
    {
      "start": 351.783,
      "end": 354.033,
      "text": "war plötzlich beschränkt"
    },
    {
      "start": 351.783,
      "end": 354.033,
      "text": "und sehr wertvoll."
    },
    {
      "start": 354.08299999999997,
      "end": 356.16700000000003,
      "text": "Nur war sie das"
    },
    {
      "start": 354.08299999999997,
      "end": 356.16700000000003,
      "text": "eigentlich schon immer."
    },
    {
      "start": 356.217,
      "end": 358.0,
      "text": "Deine Eltern zum Beispiel,"
    },
    {
      "start": 358.05,
      "end": 360.617,
      "text": "als Kind verbringst du"
    },
    {
      "start": 358.05,
      "end": 360.617,
      "text": "quasi jeden Tag mit ihnen."
    },
    {
      "start": 360.667,
      "end": 361.667,
      "text": "(Lachen)"
    },
    {
      "start": 361.717,
      "end": 363.933,
      "text": "Das wird weniger,"
    },
    {
      "start": 361.717,
      "end": 363.933,
      "text": "wenn du dir als Teenager"
    },
    {
      "start": 363.983,
      "end": 366.0,
      "text": "deine eigene Identität erkämpfst."
    },
    {
      "start": 366.267,
      "end": 369.95,
      "text": "Aber auch als Teenager siehst du"
    },
    {
      "start": 366.267,
      "end": 369.95,
      "text": "deine Eltern wahrscheinlich noch oft."
    },
    {
      "start": 370.0,
      "end": 373.333,
      "text": "Das ändert sich so um die 20,"
    },
    {
      "start": 370.0,
      "end": 373.333,
      "text": "wenn die meisten Leute ausziehen,"
    },
    {
      "start": 373.383,
      "end": 377.767,
      "text": "um zur Uni zu gehen, für einen Job"
    },
    {
      "start": 373.383,
      "end": 377.767,
      "text": "oder einfach, um alleine zu wohnen."
    },
    {
      "start": 378.033,
      "end": 379.433,
      "text": "Sagen wir,"
    },
    {
      "start": 378.033,
      "end": 379.433,
      "text": "du bemühst dich,"
    },
    {
      "start": 379.567,
      "end": 382.317,
      "text": "deine Eltern insgesamt"
    },
    {
      "start": 379.567,
      "end": 382.317,
      "text": "zwei Wochen im Jahr zu sehen,"
    },
    {
      "start": 382.367,
      "end": 384.16700000000003,
      "text": "für den Rest ihres Lebens."
    },
    {
      "start": 384.217,
      "end": 386.283,
      "text": "Das deckt"
    },
    {
      "start": 384.217,
      "end": 386.283,
      "text": "die wichtigsten Feiertage ab,"
    },
    {
      "start": 386.33299999999997,
      "end": 388.45,
      "text": "Geburtstage"
    },
    {
      "start": 386.33299999999997,
      "end": 388.45,
      "text": "und noch ein bisschen mehr."
    },
    {
      "start": 388.5,
      "end": 391.183,
      "text": "Das heißt,"
    },
    {
      "start": 388.5,
      "end": 391.183,
      "text": "dass bereits 90 Prozent der Zeit,"
    },
    {
      "start": 391.25,
      "end": 393.617,
      "text": "die du je mit deinen Eltern"
    },
    {
      "start": 391.25,
      "end": 393.617,
      "text": "verbringen wirst,"
    },
    {
      "start": 393.66700000000003,
      "end": 396.4,
      "text": "vorbei sind,"
    },
    {
      "start": 393.66700000000003,
      "end": 396.4,
      "text": "selbst wenn sie richtig alt werden."
    },
    {
      "start": 396.45,
      "end": 399.867,
      "text": "Sterben sie früher oder siehst du sie"
    },
    {
      "start": 396.45,
      "end": 399.867,
      "text": "nur ein paar Tage pro Jahr,"
    },
    {
      "start": 399.91700000000003,
      "end": 402.15,
      "text": "schrumpft die verbleibende Zeit"
    },
    {
      "start": 399.91700000000003,
      "end": 402.15,
      "text": "noch mehr."
    },
    {
      "start": 402.2,
      "end": 404.817,
      "text": "Ziemlich sicher ist also"
    },
    {
      "start": 402.2,
      "end": 404.817,
      "text": "der größte Teil der Zeit,"
    },
    {
      "start": 404.867,
      "end": 407.267,
      "text": "die du mit deinen Eltern hast,"
    },
    {
      "start": 404.867,
      "end": 407.267,
      "text": "bereits vorbei."
    },
    {
      "start": 407.317,
      "end": 408.317,
      "text": "(Ruhige Musik)"
    },
    {
      "start": 408.367,
      "end": 411.117,
      "text": "Das Gleiche gilt"
    },
    {
      "start": 408.367,
      "end": 411.117,
      "text": "für deine Geschwister oder Freunde,"
    },
    {
      "start": 411.16700000000003,
      "end": 412.25,
      "text": "die weggezogen sind."
    },
    {
      "start": 412.3,
      "end": 415.017,
      "text": "Mit einigen der wichtigsten Leute"
    },
    {
      "start": 412.3,
      "end": 415.017,
      "text": "in deinem Leben,"
    },
    {
      "start": 415.067,
      "end": 418.267,
      "text": "hast du die Endphase eurer"
    },
    {
      "start": 415.067,
      "end": 418.267,
      "text": "gemeinsamen Zeit bereits erreicht."
    },
    {
      "start": 418.317,
      "end": 421.533,
      "text": "Eines Tages wirst du sie"
    },
    {
      "start": 418.317,
      "end": 421.533,
      "text": "zum letzten Mal gesehen haben."
    },
    {
      "start": 421.583,
      "end": 423.983,
      "text": "Und genauso ist es auch"
    },
    {
      "start": 421.583,
      "end": 423.983,
      "text": "mit allem anderen."
    },
    {
      "start": 424.033,
      "end": 427.85,
      "text": "Der Gedanke, etwas zum allerletzten"
    },
    {
      "start": 424.033,
      "end": 427.85,
      "text": "Mal zu tun, ist unheimlich."
    },
    {
      "start": 427.9,
      "end": 430.467,
      "text": "Ein Gefühl,"
    },
    {
      "start": 427.9,
      "end": 430.467,
      "text": "das irgendwie nur die haben sollten,"
    },
    {
      "start": 430.517,
      "end": 432.383,
      "text": "die auf die Todesstrafe warten"
    },
    {
      "start": 432.433,
      "end": 434.233,
      "text": "oder uralt sind oder so."
    },
    {
      "start": 434.767,
      "end": 436.717,
      "text": "Es passiert aber ständig."
    },
    {
      "start": 437.16700000000003,
      "end": 440.95,
      "text": "Hast du ein Hobby, dem du schon lange"
    },
    {
      "start": 437.16700000000003,
      "end": 440.95,
      "text": "nicht mehr nachgegangen bist?"
    },
    {
      "start": 441.0,
      "end": 443.66700000000003,
      "text": "Hast du vielleicht immer noch"
    },
    {
      "start": 441.0,
      "end": 443.66700000000003,
      "text": "diese Spielfigürchen,"
    },
    {
      "start": 443.717,
      "end": 445.0,
      "text": "die du bemalen wolltest?"
    },
    {
      "start": 445.05,
      "end": 447.483,
      "text": "Wolltest du immer schon mal"
    },
    {
      "start": 445.05,
      "end": 447.483,
      "text": "an den Ort zurück,"
    },
    {
      "start": 447.533,
      "end": 449.933,
      "text": "wo es dir vor zehn Jahren"
    },
    {
      "start": 447.533,
      "end": 449.933,
      "text": "so gut gefallen hat?"
    },
    {
      "start": 450.0,
      "end": 451.733,
      "text": "Gibt es jemanden,"
    },
    {
      "start": 450.0,
      "end": 451.733,
      "text": "bei dem du dich"
    },
    {
      "start": 451.783,
      "end": 453.817,
      "text": "schon lange"
    },
    {
      "start": 451.783,
      "end": 453.817,
      "text": "mal wieder melden wolltest?"
    },
    {
      "start": 453.867,
      "end": 456.41700000000003,
      "text": "Oder einen Sport,"
    },
    {
      "start": 453.867,
      "end": 456.41700000000003,
      "text": "den du wieder machen möchtest,"
    },
    {
      "start": 456.467,
      "end": 457.967,
      "text": "um neue Freunde zu treffen?"
    },
    {
      "start": 458.017,
      "end": 460.867,
      "text": "Vielleicht wirst du nichts davon"
    },
    {
      "start": 458.017,
      "end": 460.867,
      "text": "jemals wieder tun."
    },
    {
      "start": 460.91700000000003,
      "end": 462.66700000000003,
      "text": "Weil das Leben dazwischenkommt."
    },
    {
      "start": 462.717,
      "end": 465.3,
      "text": "Und es plötzlich"
    },
    {
      "start": 462.717,
      "end": 465.3,
      "text": "einfach zu spät ist."
    },
    {
      "start": 465.6,
      "end": 467.317,
      "text": "Wenn die Pandemie sich beruhigt,"
    },
    {
      "start": 467.367,
      "end": 469.85,
      "text": "können wir wieder"
    },
    {
      "start": 467.367,
      "end": 469.85,
      "text": "mit Menschen Zeit verbringen,"
    },
    {
      "start": 469.9,
      "end": 471.283,
      "text": "und gemeinsam Spaß haben."
    },
    {
      "start": 471.33299999999997,
      "end": 474.85,
      "text": "Bis dahin überleg dir,"
    },
    {
      "start": 471.33299999999997,
      "end": 474.85,
      "text": "wen du am längsten umarmen willst,"
    },
    {
      "start": 474.9,
      "end": 478.5,
      "text": "und schreib ihnen, dass du"
    },
    {
      "start": 474.9,
      "end": 478.5,
      "text": "schon bald genau das tun wirst."
    },
    {
      "start": 478.58299999999997,
      "end": 481.283,
      "text": "Aber völlig egal,"
    },
    {
      "start": 478.58299999999997,
      "end": 481.283,
      "text": "wann du dieses Video schaust,"
    },
    {
      "start": 481.333,
      "end": 483.933,
      "text": "dein Leben"
    },
    {
      "start": 481.333,
      "end": 483.933,
      "text": "ist ein unglaubliches Geschenk,"
    },
    {
      "start": 483.983,
      "end": 487.317,
      "text": "es gibt jede Menge spaßige,"
    },
    {
      "start": 483.983,
      "end": 487.317,
      "text": "spannende und erfüllende Dinge,"
    },
    {
      "start": 487.367,
      "end": 488.717,
      "text": "die du tun könntest."
    },
    {
      "start": 488.767,
      "end": 490.4,
      "text": "Und es ist deine Entscheidung,"
    },
    {
      "start": 490.45,
      "end": 493.133,
      "text": "wer und was davon"
    },
    {
      "start": 490.45,
      "end": 493.133,
      "text": "dir am meisten bedeutet."
    },
    {
      "start": 493.183,
      "end": 495.15,
      "text": "Am wichtigsten ist es deshalb,"
    },
    {
      "start": 495.2,
      "end": 499.1,
      "text": "dass du diese Entscheidung"
    },
    {
      "start": 495.2,
      "end": 499.1,
      "text": "hin und wieder bewusst triffst."
    },
    {
      "start": 502.967,
      "end": 504.317,
      "text": "(Entspannte Musik)"
    },
    {
      "start": 504.367,
      "end": 505.683,
      "text": "(Vogelzwitschern)"
    }
